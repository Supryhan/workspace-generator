# Environment configurations for: {{ env_name }}
# Workspace Identifier
WORKSPACE_NAME={{ workspace.name }}

# Tech-Stack Component Settings
{% for component in components -%}
# Component: {{ component.name }}
{{ component.name | upper | replace('-', '_') }}_PORT={{ component.port or "" }}
{%- if component.database != 'none' %}
{{ component.name | upper | replace('-', '_') }}_DB_HOST={% if env_name == 'local' %}{{ component.name }}-db{% else %}remote-db-host{% endif %}
{{ component.name | upper | replace('-', '_') }}_DB_PORT=5432
{{ component.name | upper | replace('-', '_') }}_DB_NAME={{ component.name }}_db
{{ component.name | upper | replace('-', '_') }}_DB_USER=postgres
{{ component.name | upper | replace('-', '_') }}_DB_PASSWORD=postgres
{%- endif %}

{% endfor %}
