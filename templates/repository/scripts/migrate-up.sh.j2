#!/bin/bash
set -e

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
COMP_DIR="$(dirname "$SCRIPT_DIR")"

echo "Executing database migrations (up) for '{{ component.name }}'..."
cd "$COMP_DIR"

# Simulates migration tools (Flyway/Liquibase/Diesel/Prisma/etc.)
echo "Mock database connection: jdbc:{{ component.database }}://localhost:5432/{{ component.name }}_db"
echo "  [INFO] Checking database connection..."
echo "  [INFO] Successfully connected to {{ component.database }} database."
echo "  [INFO] Scanning for schema files inside migrations/..."
echo "  [INFO] Migrations successfully executed! Database schema is up to date."
